---
import {
  SITE_DESCRIPTION,
  SITE_TITLE,
  AUTHOR_LINK,
  AUTHOR_NAME,
  STARTED_AT,
  SITE_KEYWORDS,
} from '../consts';
const start = new Date(STARTED_AT).getFullYear();
const end = new Date().getFullYear();
---

<footer class="bg-white dark:bg-gray-900 px-0 md:px-6 lg:px-8">
  <div class="mx-auto w-full p-4 py-6 lg:py-8">
    <hr class="my-6 border-gray-200 sm:mx-auto dark:border-gray-700 lg:my-8" />
    <div class="sm:flex sm:items-center sm:justify-between">
      <span class="text-sm text-gray-500 sm:text-center dark:text-gray-400">
        © {start === end ? start : `${start}-${end}`}
        <a href={AUTHOR_LINK} class="hover:underline">{AUTHOR_NAME}</a>. All Rights Reserved.
      </span>
      <div class="flex mt-4 sm:justify-center sm:mt-0">
        <a href={AUTHOR_LINK} class="text-gray-500 hover:text-gray-900 dark:hover:text-white ms-5">
          <svg
            class="w-4 h-4"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 20 20"
          >
            <path
              fill="currentColor"
              d="M10 .333A9.911 9.911 0 0 0 6.866 19.65c.5.092.678-.215.678-.477 0-.237-.01-1.017-.014-1.845-2.757.6-3.338-1.169-3.338-1.169a2.627 2.627 0 0 0-1.1-1.451c-.9-.615.07-.6.07-.6a2.084 2.084 0 0 1 1.518 1.021 2.11 2.11 0 0 0 2.884.823c.044-.503.268-.973.63-1.325-2.2-.25-4.516-1.1-4.516-4.9A3.832 3.832 0 0 1 4.7 7.068a3.56 3.56 0 0 1 .095-2.623s.832-.266 2.726 1.016a9.409 9.409 0 0 1 4.962 0c1.89-1.282 2.717-1.016 2.717-1.016.366.83.402 1.768.1 2.623a3.827 3.827 0 0 1 1.02 2.659c0 3.807-2.319 4.644-4.525 4.889a2.366 2.366 0 0 1 .673 1.834c0 1.326-.012 2.394-.012 2.72 0 .263.18.572.681.475A9.911 9.911 0 0 0 10 .333Z"
            ></path>
          </svg>
          <span class="sr-only">GitHub account</span>
        </a>
        <a href="/rss.xml" class="text-gray-500 hover:text-gray-900 dark:hover:text-white ms-5">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 scale-125"
            viewBox="0 0 100 100"
            aria-hidden="true"
          >
            <path
              fill="currentColor"
              d="M26.258 64.949a8.78 8.78 0 0 0-8.78 8.784a8.782 8.782 0 1 0 17.564 0a8.78 8.78 0 0 0-8.784-8.784"
            ></path>
            <path
              fill="currentColor"
              d="M23.536 40.801c-.046 0-.09.006-.135.007v-.007h-3.464v.039a3.44 3.44 0 0 0-3.056 3.344h-.007v6.159h.041a3.43 3.43 0 0 0 3.021 3.002v.039H23.4v-.048c.045.001.09.007.135.007c12.772 0 23.173 10.321 23.311 23.061h-.033v3.464h.039a3.44 3.44 0 0 0 3.344 3.056v.007h6.158v-.041a3.43 3.43 0 0 0 3.002-3.021h.039v-3.464h-.006c-.137-19.657-16.166-35.604-35.853-35.604"
            ></path>
            <path
              fill="currentColor"
              d="M83.119 76.403C82.98 43.664 56.308 17.07 23.536 17.07c-.046 0-.09.006-.135.007v-.007h-3.464v.039a3.44 3.44 0 0 0-3.056 3.344h-.007v6.159h.041a3.43 3.43 0 0 0 3.021 3.002v.039H23.4v-.048c.045.001.09.007.135.007c25.857 0 46.902 20.967 47.041 46.792h-.035v3.464h.039a3.44 3.44 0 0 0 3.344 3.056v.007h6.159v-.041a3.43 3.43 0 0 0 3.002-3.021h.039v-3.464h-.005z"
            ></path>
          </svg>
          <span class="sr-only">RSS feed</span>
        </a>
      </div>
    </div>
  </div>
</footer>
