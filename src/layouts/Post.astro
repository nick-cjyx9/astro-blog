---
import Base from "./Base.astro";
---

<Base title={Astro.props.title}>
  <h1>{Astro.props.title}</h1>
  <p>{Astro.props.description}</p>
  <p>
    {
      new Date(Astro.props.pubDate).toLocaleDateString("zh-CN", {
        year: "numeric",
        month: "long",
        day: "numeric",
      })
    }
  </p>
  <article>
    <slot />
  </article>
</Base>
