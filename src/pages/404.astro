---
import Base from '../layouts/Base.astro';
---

<Base title="页面未找到 - 404">
  <div class="text-center py-16">
    <h1 class="text-6xl font-bold text-gray-900 dark:text-white mb-4">404</h1>
    <h2 class="text-2xl font-semibold text-gray-700 dark:text-gray-300 mb-4">页面未找到</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-8">
      抱歉，您访问的页面不存在。可能是链接错误或页面已被移动。
    </p>
    <div class="space-x-4">
      <a 
        href="/" 
        class="inline-flex items-center px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
      >
        返回首页
      </a>
      <a 
        href="/blog" 
        class="inline-flex items-center px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-600 dark:hover:bg-gray-700"
      >
        浏览文章
      </a>
    </div>
  </div>
</Base>

<script>
  // 添加搜索功能
  const searchInput = document.getElementById('search');
  if (searchInput) {
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        const query = (e.target as HTMLInputElement).value;
        if (query.trim()) {
          window.location.href = `/search?q=${encodeURIComponent(query)}`;
        }
      }
    });
  }
</script>
