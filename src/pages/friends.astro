---
import Base from "../layouts/Base.astro";
import FriendCard from "../components/FriendCard.astro";
import { getCollection } from "astro:content";
const friends = await getCollection("friend");
---

<Base 
  title="友链" 
  description={`Nick's Blog 的友情链接页面，收录了 ${friends.length} 个朋友们的网站！`}
  type="website"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- 页面标题和介绍 -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
        友情链接
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-6">
        这里汇集了一些优秀的朋友们和他们的博客，每一个都值得访问和交流
      </p>
      <div class="inline-flex items-center px-4 py-2 bg-blue-50 dark:bg-blue-900/20 rounded-full">
        <svg class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path>
        </svg>
        <span class="text-blue-600 dark:text-blue-400 font-medium">
          共收录 {friends.length} 个友链
        </span>
      </div>
    </div>

    <!-- 友链列表 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {friends.map((friend) => (
        <FriendCard friend={friend.data} />
      ))}
    </div>

    <!-- 申请友链提示 -->
    <div class="mt-16 text-center">
      <div class="bg-gradient-to-r from-blue-500 to-purple-600 rounded-lg p-8 text-white">
        <h2 class="text-2xl font-bold mb-4">想要申请友链？</h2>
        <p class="text-blue-100 mb-6">
          如果你也有优质的博客或网站，欢迎与我交换友链！
        </p>
        <div class="space-y-2 text-sm text-blue-100 mb-6">
          <p>• 网站内容积极向上，无违法违规内容</p>
          <p>• 网站能够正常访问，更新频率较为稳定</p>
          <p>• 优先考虑技术、学习、生活等主题的博客</p>
        </div>
        <a 
          href="mailto:contact@nickblog.com" 
          class="inline-flex items-center px-6 py-3 bg-white text-blue-600 rounded-lg font-medium hover:bg-blue-50 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
          联系申请友链
        </a>
      </div>
    </div>
  </div>
</Base>
