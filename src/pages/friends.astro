---
import Base from '../layouts/Base.astro';
import FriendCard from '../components/FriendCard.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_URL, SITE_DESCRIPTION, AUTHOR_AVATAR } from '../consts';
const friends = await getCollection('friend');
const siteInfoSnippet = `title: "${SITE_TITLE}"
link: "${SITE_URL}"
description: "${SITE_DESCRIPTION}"
avatar: "${AUTHOR_AVATAR}"`;
---

<Base
  title="友链"
  description={`Nick's Blog 的友情链接页面，收录了 ${friends.length} 个朋友们的网站！`}
  type="website"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <!-- 页面标题和介绍 -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">友情链接</h1>
      <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-6">
        这里收集了我的朋友们优秀的博客，欢迎申请添加你的站点！
      </p>
      <div class="inline-flex items-center px-4 py-2 bg-blue-50 dark:bg-blue-900/20 rounded-full">
        <svg
          class="w-5 h-5 text-blue-600 dark:text-blue-400 mr-2"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            fill-rule="evenodd"
            d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z"
            clip-rule="evenodd"></path>
        </svg>
        <span class="text-blue-600 dark:text-blue-400 font-medium">
          共收录 {friends.length} 个友链
        </span>
      </div>
    </div>

    <!-- 友链列表 -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
      {friends.map((friend) => <FriendCard friend={friend.data} />)}

      <!-- 申请友链卡片 -->
      <a
        id="openFriendModalBtn"
        class="group flex flex-col items-center justify-center p-6 bg-white border border-gray-200 rounded-lg shadow-sm hover:shadow-lg transition-all duration-300 dark:bg-gray-800 dark:border-gray-700 hover:scale-105 min-h-[120px]"
        style="border-top: 4px solid #3b82f6"
        role="button"
      >
        <div
          class="w-14 h-14 bg-blue-100 dark:bg-blue-900/30 rounded-full flex items-center justify-center mb-3"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24px" height="24px" viewBox="0 0 24 24"
            ><path
              fill="currentColor"
              d="M19 11h-6V5a1 1 0 0 0-2 0v6H5a1 1 0 0 0 0 2h6v6a1 1 0 0 0 2 0v-6h6a1 1 0 0 0 0-2"
              class="text-blue-600 dark:text-blue-400"></path></svg
          >
        </div>
      </a>
    </div>

    <!-- 背景遮罩 -->
    <div
      id="modal-backdrop"
      class="fixed inset-0 bg-black/60 z-40 hidden transition-opacity duration-300"
    >
    </div>

    <!-- 友链接入弹窗 -->
    <div
      id="friend-modal"
      role="dialog"
      aria-modal="true"
      aria-labelledby="friend-modal-title"
      class="fixed inset-0 z-50 hidden p-4"
    >
      <div class="flex items-center justify-center min-h-full py-4">
        <div
          id="friend-modal-panel"
          class="w-full max-w-lg bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 transform transition-all max-h-[calc(100vh-2rem)] overflow-hidden flex flex-col"
        >
          <!-- 头部 -->
          <div
            class="flex items-center justify-between px-6 py-4 border-b border-gray-200 dark:border-gray-700 bg-gradient-to-r from-blue-50/50 to-indigo-50/50 dark:from-blue-900/20 dark:to-indigo-900/20 flex-shrink-0"
          >
            <h3 id="friend-modal-title" class="text-lg font-semibold text-gray-900 dark:text-white">
              申请友链
            </h3>
            <button
              type="button"
              class="text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 rounded-lg w-8 h-8 inline-flex items-center justify-center hover:bg-white/50 dark:hover:bg-gray-700/50 transition-colors"
              data-close-friend-modal
              aria-label="关闭"
            >
              <svg
                class="w-3.5 h-3.5"
                viewBox="0 0 14 14"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M1 1l12 12M13 1L1 13"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"></path>
              </svg>
            </button>
          </div>

          <!-- 步骤指示器 -->
          <div class="px-6 py-4 bg-gray-50/50 dark:bg-gray-800/50 flex-shrink-0">
            <div class="flex items-center justify-center gap-4 text-sm">
              <div id="step-indicator-1" class="flex items-center gap-2">
                <span
                  class="w-7 h-7 rounded-full bg-blue-600 text-white flex items-center justify-center text-xs font-medium shadow-sm"
                  >1</span
                >
                <span class="text-gray-800 dark:text-gray-200 font-medium">添加本站</span>
              </div>
              <div
                class="flex-1 h-px bg-gradient-to-r from-gray-300 to-gray-200 dark:from-gray-600 dark:to-gray-700 mx-4"
              >
              </div>
              <div id="step-indicator-2" class="flex items-center gap-2">
                <span
                  class="w-7 h-7 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 flex items-center justify-center text-xs font-medium"
                  >2</span
                >
                <span class="text-gray-500 dark:text-gray-400 font-medium">提交信息</span>
              </div>
            </div>
          </div>

          <div class="flex-1 overflow-y-auto overflow-x-hidden modal-scrollbar">
            <div class="p-6">
              <div id="friend-steps" class="relative">
                <!-- 步骤一：展示本站信息 -->
                <div id="friend-step-1" class="space-y-5 transition-all duration-250">
                  <div
                    class="bg-blue-50/50 dark:bg-blue-900/20 rounded-lg p-4 border border-blue-100 dark:border-blue-800"
                  >
                    <div class="flex items-start gap-3">
                      <div
                        class="flex-shrink-0 w-8 h-8 bg-blue-100 dark:bg-blue-800 rounded-full flex items-center justify-center"
                      >
                        <svg
                          class="w-4 h-4 text-blue-600 dark:text-blue-300"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z"
                            clip-rule="evenodd"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <h4 class="text-sm font-semibold text-blue-900 dark:text-blue-100 mb-1">
                          温馨提示
                        </h4>
                        <p class="text-sm text-blue-800 dark:text-blue-200">
                          如果你愿意的话，可以在你的站点添加本站的友链，信息如下：
                        </p>
                      </div>
                    </div>
                  </div>

                  <div class="space-y-4">
                    <div class="grid grid-cols-1 gap-4">
                      <div class="space-y-2">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300"
                          >站点标题</label
                        >
                        <input
                          value={SITE_TITLE}
                          readonly
                          class="w-full rounded-lg border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 font-mono focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500"
                        />
                      </div>
                      <div class="space-y-2">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300"
                          >链接</label
                        >
                        <input
                          value={SITE_URL}
                          readonly
                          class="w-full rounded-lg border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 font-mono focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500"
                        />
                      </div>
                      <div class="space-y-2">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300"
                          >描述</label
                        >
                        <textarea
                          readonly
                          rows="2"
                          class="w-full rounded-lg border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500"
                          >{SITE_DESCRIPTION}</textarea
                        >
                      </div>
                      <div class="space-y-2">
                        <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300"
                          >头像</label
                        >
                        <input
                          value={AUTHOR_AVATAR}
                          readonly
                          class="w-full rounded-lg border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 font-mono focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500"
                        />
                      </div>
                    </div>
                  </div>

                  <div
                    class="flex items-center -mb-[1px] justify-between pt-4 border-t border-gray-200 dark:border-gray-700"
                  >
                    <button
                      id="copy-site-info"
                      type="button"
                      class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-100 transition-colors"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M8 2a1 1 0 000 2h2a1 1 0 100-2H8z"></path>
                        <path
                          d="M3 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v6h-4.586l1.293-1.293a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L10.414 13H15v3a2 2 0 01-2 2H5a2 2 0 01-2-2V5zM15 11.586l-3-3a1 1 0 00-1.414 1.414L11.586 11H9a1 1 0 100 2h2.586l-1 1a1 1 0 001.414 1.414l3-3a1 1 0 000-1.414z"
                        ></path>
                      </svg>
                      复制信息
                    </button>
                    <button
                      id="go-to-step-2"
                      type="button"
                      class="inline-flex items-center gap-2 px-5 py-2 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 text-white shadow-sm transition-colors"
                    >
                      下一步
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                          clip-rule="evenodd"></path>
                      </svg>
                    </button>
                  </div>
                  <textarea id="site-info-snippet" class="sr-only" readonly
                    >{siteInfoSnippet}</textarea
                  >
                </div>

                <!-- 步骤二：申请表单 -->
                <div id="friend-step-2" class="hidden transition-all duration-250 space-y-5">
                  <div
                    class="bg-green-50/50 dark:bg-green-900/20 rounded-lg p-4 border border-green-100 dark:border-green-800"
                  >
                    <div class="flex items-start gap-3">
                      <div
                        class="flex-shrink-0 w-8 h-8 bg-green-100 dark:bg-green-800 rounded-full flex items-center justify-center"
                      >
                        <svg
                          class="w-4 h-4 text-green-600 dark:text-green-300"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                        </svg>
                      </div>
                      <div class="flex-1">
                        <h4 class="text-sm font-semibold text-green-900 dark:text-green-100 mb-1">
                          提交申请
                        </h4>
                        <p class="text-sm text-green-800 dark:text-green-200">
                          请填写你的站点信息，我们会在审核通过后添加友链。
                        </p>
                      </div>
                    </div>
                  </div>

                  <form id="friend-apply-form" class="space-y-4">
                    <div class="space-y-2">
                      <label
                        for="f-title"
                        class="block text-sm font-semibold text-gray-900 dark:text-white"
                        >站点标题</label
                      >
                      <input
                        type="text"
                        id="f-title"
                        name="title"
                        required
                        class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 transition-colors"
                        placeholder="你的站点标题"
                      />
                      <p id="err-title" class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
                    </div>
                    <div class="space-y-2">
                      <label
                        for="f-link"
                        class="block text-sm font-semibold text-gray-900 dark:text-white"
                        >链接</label
                      >
                      <input
                        type="url"
                        id="f-link"
                        name="link"
                        required
                        class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 transition-colors"
                        placeholder="https://example.com"
                      />
                      <p id="err-link" class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
                    </div>
                    <div class="space-y-2">
                      <label
                        for="f-desc"
                        class="block text-sm font-semibold text-gray-900 dark:text-white"
                        >描述</label
                      >
                      <textarea
                        id="f-desc"
                        name="description"
                        rows="3"
                        required
                        class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 transition-colors"
                        placeholder="一句话介绍你的站点"></textarea>
                      <p id="err-description" class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
                    </div>
                    <div class="space-y-2">
                      <label
                        for="f-mail"
                        class="block text-sm font-semibold text-gray-900 dark:text-white"
                        >邮箱</label
                      >
                      <input
                        type="email"
                        id="f-mail"
                        name="email"
                        class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 transition-colors"
                        placeholder="your@email.com"
                        aria-describedby="f-mail-help"
                      />
                      <p id="f-mail-help" class="text-xs text-gray-500 dark:text-gray-400">
                        可选，用于友链审核结果通知
                      </p>
                      <p id="err-mail" class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
                    </div>
                    <div class="space-y-2">
                      <label
                        for="f-avatar"
                        class="block text-sm font-semibold text-gray-900 dark:text-white"
                        >头像（URL）</label
                      >
                      <input
                        type="url"
                        id="f-avatar"
                        name="avatar"
                        class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm px-3 py-2.5 focus:ring-2 focus:ring-blue-500/40 focus:border-blue-500 transition-colors"
                        placeholder="https://.../avatar.png"
                      />
                      <p id="err-avatar" class="hidden text-xs text-red-600 dark:text-red-400 mt-1"></p>
                    </div>

                    <!-- 通用错误提示区域（Actions 错误显示） -->
                    <div id="form-error" class="hidden bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-3">
                      <div class="flex items-start gap-2">
                        <svg class="w-4 h-4 text-red-600 dark:text-red-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.257 3.099c.366-.446 1.12-.201 1.12.37v6.062a.75.75 0 01-1.5 0V3.47c0-.246.089-.371.38-.371zm.743 11.651a1.25 1.25 0 110 2.5 1.25 1.25 0 010-2.5z" clip-rule="evenodd" />
                        </svg>
                        <p id="form-error-message" class="text-sm text-red-700 dark:text-red-300"></p>
                      </div>
                    </div>

                    <div
                      class="flex items-center justify-between pt-4 border-t border-gray-200 dark:border-gray-700"
                    >
                      <button
                        id="back-to-step-1"
                        type="button"
                        class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-gray-100 transition-colors"
                      >
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                          <path
                            fill-rule="evenodd"
                            d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"
                            clip-rule="evenodd"></path>
                        </svg>
                        上一步
                      </button>
                      <button
                        type="submit"
                        id="submit-btn"
                        class="inline-flex items-center gap-2 px-5 py-2 text-sm font-medium rounded-lg bg-blue-600 hover:bg-blue-700 disabled:bg-blue-400 disabled:cursor-not-allowed text-white shadow-sm transition-colors"
                      >
                        <svg
                          id="submit-icon"
                          class="w-4 h-4"
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path
                            fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                        </svg>
                        <svg
                          id="loading-icon"
                          class="w-4 h-4 animate-spin hidden"
                          fill="none"
                          viewBox="0 0 24 24"
                        >
                          <circle
                            class="opacity-25"
                            cx="12"
                            cy="12"
                            r="10"
                            stroke="currentColor"
                            stroke-width="4"></circle>
                          <path
                            class="opacity-75"
                            fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                          ></path>
                        </svg>
                        <span id="submit-text">提交申请</span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <script>
        import { actions, isActionError, isInputError } from 'astro:actions';

        (function () {
          const openBtn = document.getElementById('openFriendModalBtn');
          const modal = document.getElementById('friend-modal');
          const backdrop = document.getElementById('modal-backdrop');
          const panel = document.getElementById('friend-modal-panel');
          const stepsContainer = document.getElementById('friend-steps');
          const step1 = document.getElementById('friend-step-1');
          const step2 = document.getElementById('friend-step-2');
          const ind1 = document.getElementById('step-indicator-1');
          const ind2 = document.getElementById('step-indicator-2');
          const goStep2 = document.getElementById('go-to-step-2');
          const backStep1 = document.getElementById('back-to-step-1');
          const copyBtn = document.getElementById('copy-site-info');
          const snippetEl = document.getElementById('site-info-snippet');
          const form = document.getElementById('friend-apply-form');
          const submitBtn = document.getElementById('submit-btn');
          const submitText = document.getElementById('submit-text');
          const submitIcon = document.getElementById('submit-icon');
          const loadingIcon = document.getElementById('loading-icon');
          const formError = document.getElementById('form-error');
          const formErrorMessage = document.getElementById('form-error-message');
          const descTextarea = document.getElementById('f-desc');
          const descCounter = document.getElementById('desc-counter');

          const titleInput = document.getElementById('f-title') as HTMLInputElement | null;
          const linkInput = document.getElementById('f-link') as HTMLInputElement | null;
          const descInput = document.getElementById('f-desc') as HTMLTextAreaElement | null;
          const mailInput = document.getElementById('f-mail') as HTMLInputElement | null;
          const avatarInput = document.getElementById('f-avatar') as HTMLInputElement | null;

          const errTitle = document.getElementById('err-title');
          const errLink = document.getElementById('err-link');
          const errDesc = document.getElementById('err-description');
          const errMail = document.getElementById('err-mail');
          const errAvatar = document.getElementById('err-avatar');

          function show(el: HTMLElement | null | undefined) {
            el && el.classList.remove('hidden');
          }
          function hide(el: HTMLElement | null | undefined) {
            el && el.classList.add('hidden');
          }

          // 字符计数器
          if (descTextarea && descCounter) {
            descTextarea.addEventListener('input', () => {
              const count = (descTextarea as HTMLTextAreaElement).value.length;
              descCounter.textContent = count.toString();
              descCounter.parentElement!.classList.toggle('text-red-500', count > 100);
              descCounter.parentElement!.classList.toggle('text-gray-500', count <= 100);
              descCounter.parentElement!.classList.toggle('dark:text-red-400', count > 100);
              descCounter.parentElement!.classList.toggle('dark:text-gray-400', count <= 100);
            });
          }

          // 清除字段错误
          function setFieldError(el: HTMLElement | null, inputEl: HTMLInputElement | HTMLTextAreaElement | null, msg?: string) {
            if (!el || !inputEl) return;
            if (msg) {
              el.textContent = msg;
              el.classList.remove('hidden');
              inputEl.setAttribute('aria-invalid', 'true');
              inputEl.classList.add('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/40');
            } else {
              el.textContent = '';
              el.classList.add('hidden');
              inputEl.removeAttribute('aria-invalid');
              inputEl.classList.remove('border-red-500', 'focus:border-red-500', 'focus:ring-red-500/40');
            }
          }

          // 错误处理（通用）
          function showError(message: string) {
            if (formError && formErrorMessage) {
              formErrorMessage.textContent = message;
              formError.classList.remove('hidden');
              formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
          }

          function hideError() {
            if (formError) formError.classList.add('hidden');
          }

          // 提交按钮状态
          function setSubmitting(isSubmitting: boolean) {
            if (!(submitBtn && submitText && submitIcon && loadingIcon)) return;

            if (isSubmitting) {
              (submitBtn as HTMLButtonElement).disabled = true;
              submitText.textContent = '提交中...';
              hide(submitIcon);
              show(loadingIcon);
            } else {
              (submitBtn as HTMLButtonElement).disabled = false;
              submitText.textContent = '提交申请';
              show(submitIcon);
              hide(loadingIcon);
            }
          }

          function activateStepIndicator(step: 1 | 2) {
            if (!(ind1 && ind2)) return;
            const dot1 = ind1.querySelector('span');
            const dot2 = ind2.querySelector('span');
            if (step === 1) {
              ind1.classList.remove('text-gray-500', 'dark:text-gray-400');
              ind2.classList.add('text-gray-500', 'dark:text-gray-400');
              if (dot1) {
                dot1.classList.remove(
                  'bg-gray-200',
                  'dark:bg-gray-700',
                  'text-gray-700',
                  'dark:text-gray-300'
                );
                dot1.classList.add('bg-blue-600', 'text-white');
              }
              if (dot2) {
                dot2.classList.add(
                  'bg-gray-200',
                  'dark:bg-gray-700',
                  'text-gray-700',
                  'dark:text-gray-300'
                );
                dot2.classList.remove('bg-blue-600', 'text-white');
              }
            } else {
              ind2.classList.remove('text-gray-500', 'dark:text-gray-400');
              ind1.classList.add('text-gray-500', 'dark:text-gray-400');
              if (dot2) {
                dot2.classList.remove(
                  'bg-gray-200',
                  'dark:bg-gray-700',
                  'text-gray-700',
                  'dark:text-gray-300'
                );
                dot2.classList.add('bg-blue-600', 'text-white');
              }
              if (dot1) {
                dot1.classList.add(
                  'bg-gray-200',
                  'dark:bg-gray-700',
                  'text-gray-700',
                  'dark:text-gray-300'
                );
                dot1.classList.remove('bg-blue-600', 'text-white');
              }
            }
          }

          function openModal() {
            if (!(modal && backdrop && panel)) return;
            show(backdrop as HTMLElement);
            show(modal as HTMLElement);

            // 重置状态
            hideError();
            setSubmitting(false);
            if (stepsContainer) (stepsContainer as HTMLElement).style.height = '';
            if (form) (form as HTMLFormElement).reset();
            if (descCounter) descCounter.textContent = '0';

            // 动画
            backdrop.classList.add('opacity-0');
            panel.classList.add('opacity-0', 'translate-y-4', 'sm:translate-y-0', 'sm:scale-95');
            panel.classList.add('transition-all', 'duration-250');
            backdrop.classList.add('transition-opacity', 'duration-250');
            requestAnimationFrame(() => {
              backdrop.classList.remove('opacity-0');
              panel.classList.remove('opacity-0', 'translate-y-4', 'sm:scale-95');
            });
            activateStepIndicator(1);
            document.documentElement.classList.add('overflow-hidden');
            document.body.classList.add('overflow-hidden');

            // 聚焦第一个输入框
            setTimeout(() => {
              const firstInput = step1?.querySelector('input, textarea') as HTMLInputElement;
              firstInput?.focus();
            }, 300);
          }

          function closeModal() {
            if (!(modal && backdrop && panel)) return;
            backdrop.classList.add('opacity-0');
            panel.classList.add('opacity-0', 'translate-y-4', 'sm:scale-95');
            const done = () => {
              hide(backdrop as HTMLElement);
              hide(modal as HTMLElement);
              panel.classList.remove('opacity-0', 'translate-y-4', 'sm:scale-95');
              if (stepsContainer) (stepsContainer as HTMLElement).style.height = '';
              // 重置到第一步
              if (step1 && step2) {
                show(step1);
                hide(step2);
                activateStepIndicator(1);
              }
            };
            setTimeout(done, 250);
          }

          function switchStep(
            fromEl: HTMLElement,
            toEl: HTMLElement,
            direction: 'forward' | 'backward'
          ) {
            const container = stepsContainer as HTMLElement | null;
            if (!container) {
              show(toEl);
              requestAnimationFrame(() => {
                fromEl.classList.add('opacity-0');
                toEl.classList.remove('hidden');
              });
              setTimeout(() => {
                hide(fromEl);
                fromEl.classList.remove('opacity-0');
              }, 250);
              return;
            }

            show(toEl);
            const startHeight = fromEl.getBoundingClientRect().height;
            container.style.height = startHeight + 'px';
            container.style.transition = 'height 250ms ease';

            fromEl.style.position = 'absolute';
            fromEl.style.inset = '0';
            toEl.style.position = 'absolute';
            toEl.style.inset = '0';

            const trans = 'opacity 250ms ease, transform 250ms ease';
            fromEl.style.transition = trans;
            toEl.style.transition = trans;
            fromEl.style.opacity = '1';
            fromEl.style.transform = 'translateX(0)';
            toEl.style.opacity = '0';
            toEl.style.transform =
              direction === 'forward' ? 'translateX(16px)' : 'translateX(-16px)';

            const endHeight = toEl.getBoundingClientRect().height;

            requestAnimationFrame(() => {
              container.style.height = endHeight + 'px';
              fromEl.style.opacity = '0';
              fromEl.style.transform =
                direction === 'forward' ? 'translateX(-16px)' : 'translateX(16px)';
              toEl.style.opacity = '1';
              toEl.style.transform = 'translateX(0)';
            });

            setTimeout(() => {
              hide(fromEl);
              container.style.height = '';
              container.style.transition = '';

              [fromEl, toEl].forEach((el) => {
                el.style.position = '';
                el.style.inset = '';
                el.style.transition = '';
                el.style.opacity = '';
                el.style.transform = '';
              });

              // 聚焦目标步骤的第一个输入框
              const firstInput = toEl.querySelector(
                'input:not([readonly]), textarea'
              ) as HTMLInputElement;
              firstInput?.focus();
            }, 270);
          }

          // 事件监听器
          openBtn &&
            openBtn.addEventListener('click', (e) => {
              e.preventDefault();
              openModal();
            });
          backdrop && backdrop.addEventListener('click', closeModal);
          document
            .querySelectorAll('[data-close-friend-modal]')
            .forEach((btn) => btn.addEventListener('click', closeModal));
          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !(submitBtn as HTMLButtonElement)?.disabled) closeModal();
          });

          goStep2 &&
            goStep2.addEventListener('click', () => {
              if (step1 && step2) {
                hideError();
                switchStep(step1 as HTMLElement, step2 as HTMLElement, 'forward');
                activateStepIndicator(2);
              }
            });

          backStep1 &&
            backStep1.addEventListener('click', () => {
              if (step1 && step2) {
                hideError();
                switchStep(step2 as HTMLElement, step1 as HTMLElement, 'backward');
                activateStepIndicator(1);
              }
            });

          copyBtn &&
            copyBtn.addEventListener('click', async () => {
              const textStr = (function () {
                if (!snippetEl) return '';
                const anyEl = snippetEl as any;
                if (typeof anyEl.value === 'string') return anyEl.value as string;
                const tc = snippetEl.textContent;
                return typeof tc === 'string' ? tc : '';
              })();

              try {
                await navigator.clipboard.writeText(textStr);
                const originalText = copyBtn.innerHTML;
                copyBtn.innerHTML = '✓ 已复制';
                copyBtn.classList.add(
                  'bg-green-100',
                  'text-green-700',
                  'dark:bg-green-800',
                  'dark:text-green-200'
                );
                setTimeout(() => {
                  copyBtn.innerHTML = originalText;
                  copyBtn.classList.remove(
                    'bg-green-100',
                    'text-green-700',
                    'dark:bg-green-800',
                    'dark:text-green-200'
                  );
                }, 2000);
              } catch (error) {
                console.error('复制失败:', error);
                // 降级方案
                const ta = document.createElement('textarea');
                ta.value = textStr;
                document.body.appendChild(ta);
                ta.select();
                document.execCommand('copy');
                document.body.removeChild(ta);
                copyBtn.textContent = '已复制';
                setTimeout(() => {
                  copyBtn.innerHTML = '复制信息';
                }, 2000);
              }
            });

          form &&
            form.addEventListener('submit', async (e) => {
              e.preventDefault();

              const formEl = form as HTMLFormElement;
              const formData = new FormData(formEl);
              const title = formData.get('title') as string;
              const link = formData.get('link') as string;
              const description = formData.get('description') as string;
              const avatar = formData.get('avatar') as string;
              const email = formData.get('email') as string;

              hideError();

              if (!title.trim()) {
                setFieldError(errTitle as HTMLElement, titleInput, '请填写站点标题');
                return;
              }
              if (!link.trim()) {
                setFieldError(errLink as HTMLElement, linkInput, '请填写站点链接');
                return;
              }
              if (!description.trim()) {
                setFieldError(errDesc as HTMLElement, descInput as any, '请填写站点描述');
                return;
              }
              if (description.length > 100) {
                setFieldError(errDesc as HTMLElement, descInput as any, '站点描述不能超过100个字符');
                return;
              }

              // URL 基础校验
              try {
                new URL(link);
              } catch {
                setFieldError(errLink as HTMLElement, linkInput, '请输入有效的网站地址');
                return;
              }

              setSubmitting(true);

              try {
                const result = await actions.sendFriendForm({
                  title: title.trim(),
                  link: link.trim(),
                  description: description.trim(),
                  avatar: avatar?.trim() || '',
                  mail: email?.trim() || '',
                });

                if (result.error) {
                  // 处理输入错误（来自 Zod）
                  if (isInputError(result.error)) {
                    const fields = (result.error as any).fields || {};
                    if (fields.title?.length) setFieldError(errTitle as HTMLElement, titleInput, fields.title.join(','));
                    if (fields.link?.length) setFieldError(errLink as HTMLElement, linkInput, fields.link.join(','));
                    if (fields.description?.length) setFieldError(errDesc as HTMLElement, descInput as any, fields.description.join(','));
                    if (fields.avatar?.length) setFieldError(errAvatar as HTMLElement, avatarInput, fields.avatar.join(','));
                  } else {
                    // 其它后端错误（ActionError）
                    showError(result.error.message || '提交失败，请稍后重试');
                  }
                  return;
                }

                // 成功提示
                const successMsg = document.createElement('div');
                successMsg.className =
                  'fixed bottom-4 right-4 bg-green-100 dark:bg-green-900/20 border border-green-200 dark:border-green-800 text-green-800 dark:text-green-200 px-4 py-3 rounded-lg shadow-lg z-[60] transition-all duration-300';
                successMsg.innerHTML = `
              <div class="flex items-center gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <span>申请提交成功！我会尽快审核你的友链申请。</span>
              </div>
            `;
                document.body.appendChild(successMsg);

                setTimeout(() => {
                  successMsg.style.opacity = '0';
                  successMsg.style.transform = 'translateX(100%)';
                  setTimeout(() => document.body.removeChild(successMsg), 300);
                }, 4000);

                closeModal();
              } catch (error: any) {
                // 网络或未知错误
                console.error('提交失败:', error);
                if (isActionError?.(error)) {
                  showError(error.message || '提交失败，请稍后重试');
                } else {
                  showError('网络异常或服务器不可用，请稍后重试');
                }
              } finally {
                setSubmitting(false);
              }
            });
        })();
      </script>
    </div>
  </div>
</Base>
